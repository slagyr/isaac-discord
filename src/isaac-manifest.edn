{:id      :isaac.comm.discord
 :version "0.1.2"
 :factory isaac.module.protocol/module

 :isaac.server/service
 {:discord {:namespace isaac.comm.discord.service}}

 ;; Comm contributions live on the :isaac.server/comm berth — the berth the
 ;; server's [:comms] config slot composes :extra-schema from (see
 ;; isaac-server isaac-manifest.edn :comms :dynamic-schema). Declaring under
 ;; :isaac.agent/comm activates the comm (the factory falls back to it) but
 ;; leaves its fields out of the composed schema, so conform strips :discord/token.
 :isaac.server/comm
 {:discord {:namespace    isaac.comm.discord
            :extra-schema {:discord/token       {:type        :string
                                                 :validations [[:present-when? :type :discord]]
                                                 :description "Discord bot token. Use ${ENV_VAR} for env substitution from the state-dir .env file."}
                           :discord/message-cap {:type        :int
                                                 :validations [[:nil-or? [:between 1 2000]]]
                                                 :description "Maximum reply length in characters before splitting. Discord's hard cap is 2000."}
                           :discord/allow-from  {:type        :map
                                                 :schema      {:users  {:type        :seq
                                                                        :spec        {:type :string}
                                                                        :description "Discord user IDs (snowflake strings) allowed to DM the bot."}
                                                               :guilds {:type        :seq
                                                                        :spec        {:type :string}
                                                                        :description "Guild (server) IDs the bot accepts messages from."}}
                                                 :description "Inbound-message allowlist with two keys: :users and :guilds."}
                           :discord/channels    {:type        :map
                                                 :key-spec    {:type :string}
                                                 :value-spec  {:type   :map
                                                               :schema {:name {:type        :string
                                                                               :description "Friendly display name; surfaced to the LLM as channel_label metadata."}
                                                                        :session {:type        :string
                                                                                  :description "Explicit session id for messages from this channel"}
                                                                        :session-tags {:type        :seq
                                                                                       :description "Tags the target session must carry (AND)"
                                                                                       :spec        {:type :keyword}}
                                                                        :crew {:type        :string
                                                                               :validations [[:nil-or? [:crew-exists?]]]
                                                                               :description "Crew for session selection or creation. Overrides the slot-level :crew."}
                                                                        :reach {:type        :keyword
                                                                                :description "How many sessions to target (:one for Discord)"
                                                                                :validations [[:one-of? :one :all]]}
                                                                        :prefer {:type        :keyword
                                                                                 :description "Multi-match tiebreak when :reach is :one"
                                                                                 :validations [[:one-of? :recent :oldest]]}
                                                                        :create {:type        :keyword
                                                                                 :description "Create policy: :never, :if-missing, or :always (Discord default :if-missing)"
                                                                                 :validations [[:one-of? :never :if-missing :always]]}
                                                                        :with-crew {:type        :string
                                                                                    :description "Override crew for the inbound turn"}
                                                                        :with-model {:type        :string
                                                                                     :validations [[:nil-or? [:model-exists?]]]
                                                                                     :description "Override model for this channel. Overrides the slot-level :model."}
                                                                        :with-effort {:type :int
                                                                                      :description "Override effort for the inbound turn"}
                                                                        :with-context-mode {:type        :keyword
                                                                                            :description "Override context mode for the inbound turn"}}}
                                                 :description "Per-channel session frequencies: map of Discord channel ID to selection + :with-* override keys (plus optional :name)."}}
            :send-schema  {:discord/target {:type        :string
                                            :description "Discord channel to post to: snowflake ID or the channel :name from :discord/channels."}}}}}